      m_Calls: []
  m_text: "\r\n\u041F\u0420\u0410\u0412\u0418\u041B\u0410 \u0418\u0413\u0420\u042B\r\n\r\n\u0412\u044B
    \u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u043E\u043F\u0440\u043E\u0431\u043E\u0432\u0430\u0442\u044C
    \u043E\u0442\u0433\u0430\u0434\u0430\u0442\u044C \u043A\u043E\u0434 \u0441\u0430\u043C\u0438
    \u043F\u0440\u043E\u043A\u0440\u0443\u0447\u0438\u0432\u0430\u044F \u0431\u0430\u0440\u0430\u0431\u0430\u043D\u044B
    \u0438\u043B\u0438 \u0440\u0430\u0437\u0433\u0430\u0434\u0430\u0442\u044C \u0437\u0430\u0433\u0430\u0434\u043A\u0443
    \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439
    \u043E\u0442\u0432\u0435\u0442.\n\r\n\u0412 \u043A\u043E\u043C\u043D\u0430\u0442\u0435
    8 \u0448\u0430\u0440\u043E\u0432.\r\n\u041D\u043E, \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 4 \u0446\u0438\u0444\u0440\u044B \u0438\u0437 \u043A\u043E\u0434\u0430.\r\n\r\n\u041F\u043E\u043A\u0440\u0443\u0442\u0438
    \u0431\u0430\u0440\u0430\u0431\u0430\u043D\u044B \u043D\u0430 \u0448\u043A\u0430\u0442\u0443\u043B\u043A\u0435\r\n\u0438
    \u0432\u044B\u0441\u0442\u0430\u0432\u044C \u0446\u0438\u0444\u0440\u044B \u0432
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u043C \u043F\u043E\u0440\u044F\u0434\u043A\u0435.\r\n
    \r\n\u041A\u043E\u0433\u0434\u0430 \u0432\u0441\u0435 4 \u0446\u0438\u0444\u0440\u044B
    \u0441\u043E\u0432\u043F\u0430\u0434\u0443\u0442 \u2014\r\n\u0448\u043A\u0430\u0442\u0443\u043B\u043A\u0430
    \u043E\u0442\u043A\u0440\u043E\u0435\u0442\u0441\u044F.\r\n\r\n\u0412\u043D\u0443\u0442\u0440\u0438
    \u0448\u043A\u0430\u0442\u0443\u043B\u043A\u0438 \u0442\u0435\u0431\u044F \u0436\u0434\u0451\u0442\r\n\u041D\u0410\u0421\u0422\u041E\u042F\u0429\u0418\u0419
    \u041A\u0423\u0411\u041E\u041A!\r\n\r\n\u0423\u0414\u0410\u0427\u0418, \u0418\u0421\u041A\u0410\u0422\u0415\u041B\u042C!"
